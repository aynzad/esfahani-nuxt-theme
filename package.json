{
  "name": "esfahani-nuxt-theme",
  "version": "2.1.0",
  "private": false,
  "type": "module",
  "description": "A personal website/weblog theme based on Nuxt & Prismic for esfahani.dev",
  "author": "Alireza Esfahani <alireza@esfahani.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aynzad/esfahani-nuxt-theme.git"
  },
  "bugs": {
    "url": "https://github.com/aynzad/esfahani-nuxt-theme/issues"
  },
  "homepage": "https://github.com/aynzad/esfahani-nuxt-theme#readme",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "check": "prettier --check . && pnpm run lint && pnpm run typecheck && pnpm run test",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.79",
    "@nuxtjs/i18n": "^9.5.0",
    "@nuxtjs/mdc": "^0.13.0",
    "@nuxtjs/prismic": "^5.0.0",
    "@nuxtjs/sitemap": "^7.0.0",
    "@prismicio/client": "^7.10.0",
    "@prismicio/vue": "^5.1.0",
    "ai": "^6.0.191",
    "feed": "^5.2.1",
    "nuxt": "^4.0.0",
    "nuxt-gtag": "^4.0.0",
    "nuxt-og-image": "^6.5.1",
    "nuxt-schema-org": "^6.0.4",
    "nuxt-seo-utils": "^7.0.19",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.0.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/test-utils": "^4.0.3",
    "@takumi-rs/core": "^1.5.1",
    "@types/node": "^25.9.1",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^9.18.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "sass": "^1.83.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.2"
  }
}
