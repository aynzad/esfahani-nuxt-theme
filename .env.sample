NUXT_PUBLIC_API_URL=https://your-repo.cdn.prismic.io/api/v2
NUXT_PUBLIC_SITE_URL=http://your-domain.com
# Use a GA4 measurement ID (G-XXXXXXXXXX). Legacy UA-* values are ignored.
NUXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NUXT_PUBLIC_PAGE_SIZE=10
NUXT_PUBLIC_IS_STAGING=false
# GitHub account whose public repos are listed on the Projects page.
NUXT_PUBLIC_GITHUB_USERNAME=aynzad
# Optional: a read-only PAT (public repos) to lift the 60 req/hr unauthenticated GitHub limit.
NUXT_GITHUB_TOKEN=
# Optional: Gemini API key to auto-translate the Projects page into Farsi. Empty = Farsi shows English text.
NUXT_GEMINI_API_KEY=
# Optional: override the Gemini model (defaults to gemini-2.5-flash).
NUXT_GEMINI_MODEL=gemini-2.5-flash
# A secret value used to generate OG images. If empty, the OG image endpoint will be disabled.
NUXT_OG_IMAGE_SECRET=